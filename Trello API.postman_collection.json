      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Only decrement counter if deletion was successful, and never go below 0",
              "if (pm.response.code === 200) {",
              "    let currentCount = parseInt(pm.variables.get('counter')) || 0;",
              "    let newCount = Math.max(0, currentCount - 1);",
              "    pm.environment.set(\"counter\", newCount);",
              "    pm.environment.set(\"boardCount\", newCount);",
