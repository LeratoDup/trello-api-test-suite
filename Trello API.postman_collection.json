    {
      "name": "Create board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Only increment counter if board was successfully created",
              "if (pm.response.code === 200) {",
              "    let currentCount = parseInt(pm.variables.get('curBoardCount')) || 0;",
              "    let newCount = currentCount + 1;",
              "    pm.environment.set(\"curBoardCount\", newCount);",
              "    pm.environment.set(\"boardCount\", newCount);",
              "    pm.environment.set(\"boardId\", pm.response.json().id);",
              "}",
              "",
              "",
              "let response;",
              "",
              "pm.test('Board is created', () => {",
              "    response = pm.response.json();",
              "    pm.expect(response.name).to.eql(\"Test board \" + pm.variables.get('curBoardCount'));",
              "    pm.expect(response.closed).to.eql(false);",
              "",
              "    pm.environment.set(\"boardId\", response.id);",
              "});",
              "",
              "pm.test('Board is private', () => {",
              "    response = pm.response.json();",
              "    pm.expect(response.prefs.permissionLevel).to.eql('private');",
              "});",
              "",
              "pm.test('Calendar is disabled', () => {",
              "    response = pm.response.json();",
              "    const calendarView = response.prefs.switcherViews.find(view => view.viewType === 'Calendar');",
              "    pm.expect(calendarView).to.not.be.undefined;",
              "    pm.expect(calendarView).to.be.an('object');",
              "    pm.expect(calendarView.enabled).to.be.false;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Retrieve the current counter or default to 0 if it doesn't exist yet",
              "let currentBoardCount = parseInt(pm.environment.get(\"curBoardCount\")) || 0;",
              "",
              "// Format the dynamic board name using the NEXT number (curBoardCount + 1)",
              "let dynamicBoardName = \"Test board \" + (currentBoardCount + 1);",
              "",
              "// Save the formatted string to a variable for the request",
              "pm.environment.set(\"dynamicBoardName\", dynamicBoardName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/1/boards/?name={{dynamicBoardName}}&key={{trelloKey}}&token={{trelloToken}}",
          "host": [
            "{{baseUrl}}"
