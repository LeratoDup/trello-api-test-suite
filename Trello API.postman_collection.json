    {
      "name": "Create card",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Card is created\", ()=>{\r",
              "const response = pm.response.json();\r",
              "const expectedName = decodeURIComponent(pm.request.url.query.get(\"name\"));\r",
              "pm.environment.set(\"cardName\", expectedName)\r",
              "pm.expect(response.name).to.eql(expectedName);\r",
              "pm.expect(response.idList).to.eql(pm.variables.get('toDoListId'));\r",
              "pm.expect(response.idBoard).to.eql(pm.environment.get(\"boardId\"));\r",
              "pm.expect(response.badges.attachmentsByType.trello.card).to.eql(0);\r",
              "pm.environment.set(\"cardId\", pm.response.json().id);\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Retrieve the current counter or default to 0 if it doesn't exist yet",
              "let curCardCount = parseInt(pm.environment.get(\"cardCount\")) || 0;",
              "",
              "// Format the dynamic card name using the NEXT number (curCardCount + 1)",
              "let dynamicCardName = \"Test card \" + (curCardCount + 1);",
              "",
              "// Save the formatted string to a variable for the request",
              "pm.environment.set(\"dynamicCardName\", dynamicCardName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
